PORT=5001
NODE_ENV=development
TZ=Asia/Manila
# The string WITH -pooler (for the Express app)
DATABASE_URL="postgresql://user:pass@ep-name-pooler.region.aws.neon.tech/neondb"

# The string WITHOUT -pooler (for Prisma migrations)
DIRECT_URL="postgresql://user:pass@ep-name.region.aws.neon.tech/neondb"

FRONTEND_URL="http://localhost:5173"
JWT_SECRET="change-me-super-secret"
SESSION_TTL="7d"
AUTH_COOKIE_NAME="arrowhead_session"
# Optional cookie overrides.
# Local/test default behavior: SameSite=lax, Secure=false
# Production default behavior: SameSite=none, Secure=true
# AUTH_COOKIE_SAME_SITE="lax"
# AUTH_COOKIE_SECURE=false
BCRYPT_ROUNDS=10

# Seed user configuration (do not commit real passwords)
SEED_OWNER_USERNAME="owner"
SEED_OWNER_PASSWORD="change-me-owner-password"
SEED_STAFF_USERNAME="staff"
SEED_STAFF_PASSWORD="change-me-staff-password"
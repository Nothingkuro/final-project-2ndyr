{
  "name": "arrowhead-e2e",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:headless": "cross-env E2E_HEADLESS=true playwright test",
    "test:e2e:headed": "cross-env E2E_HEADLESS=false playwright test --headed",
    "test:e2e:ci": "cross-env CI=true E2E_HEADLESS=true E2E_USE_EXISTING_FRONTEND=true E2E_USE_EXISTING_BACKEND=false playwright test",
    "test:e2e:ui": "playwright test --ui",
    "playwright:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.12.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "typescript": "^5.9.3"
  }
}
